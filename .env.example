# Get a free Groq API key at https://console.groq.com/keys
LLM_API_KEY=your-groq-api-key-here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Or use OpenAI instead:
# LLM_API_KEY=your-openai-api-key-here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# For best image replication, use a strong vision model (optional):
# VISION_MODEL=gpt-4o

# Faster model for text-only edits (optional — set to e.g. llama-3.1-8b-instant for quicker updates):
# LLM_FAST_MODEL=llama-3.1-8b-instant

# Serper API (image search fallback when scraping fails) — https://serper.dev
# SERPER_API_KEY=your-serper-api-key-here

# Google Custom Search API (100 free queries/day, forever)
# Step 1: Get API key at https://console.cloud.google.com/apis/credentials
# Step 2: Enable "Custom Search API" at https://console.cloud.google.com/apis/library/customsearch.googleapis.com
# Step 3: Create a search engine at https://programmablesearchengine.google.com/controlpanel/create
#         - Toggle "Search the entire web" ON
#         - Toggle "Image search" ON
#         - Copy the Search Engine ID (cx)
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_CSE_ID=your-custom-search-engine-id-here
